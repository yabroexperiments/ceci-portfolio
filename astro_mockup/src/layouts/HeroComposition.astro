---
// Layout 1: HERO COMPOSITION
// Full-bleed colored hero with multiple device mockups composed side-by-side.
// Used by case studies that have rich UI screenshots (e.g. BNCT — yellow bg
// with 4 phone mockups + 1 desktop). Frontmatter drives:
//   - background_color: any CSS color
//   - hero_images: array of image URLs (rendered in flex row, max-height contained)
import BaseLayout from './BaseLayout.astro';

const {
  title,
  subtitle,
  description,
  hero_images = [],
  background_color = '#F2D851',
  ...rest
} = Astro.props;
---
<BaseLayout title={title} description={description} {...rest}>
  <section class="hero" style={`background-color: ${background_color}`}>
    <div class="hero-inner">
      {hero_images.map((src) => <img src={src} alt="" loading="eager" />)}
    </div>
  </section>

  <section class="intro">
    {subtitle && <span class="subtitle">{subtitle}</span>}
    <h1>{title}</h1>
    <p class="lead">{description}</p>
  </section>

  <section class="content">
    <slot />
  </section>

  <section class="back-link">
    <a href="/">← Back to portfolio</a>
  </section>
</BaseLayout>

<style>
  .hero {
    width: 100%;
    padding: 120px 24px 80px;
    overflow: hidden;
  }
  .hero-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    gap: 24px;
    flex-wrap: wrap;
  }
  .hero-inner img {
    max-height: 480px;
    width: auto;
    object-fit: contain;
    flex: 0 1 auto;
  }
  .intro {
    max-width: 800px;
    margin: 100px auto 60px;
    padding: 0 24px;
  }
  .subtitle {
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #999;
    display: block;
    margin-bottom: 12px;
  }
  .intro h1 {
    font-size: 32px;
    margin: 0 0 24px;
  }
  .intro .lead {
    font-size: 18px;
    line-height: 1.6;
    color: #333;
    margin: 0;
  }
  .content {
    max-width: 760px;
    margin: 60px auto;
    padding: 0 24px;
  }
  .content :global(p) { margin: 0 0 1.5em; }
  .content :global(h2) { margin: 2em 0 0.5em; }
  .content :global(h3) { margin: 1.5em 0 0.5em; }
  .back-link {
    text-align: center;
    margin: 60px auto 40px;
  }
  .back-link a {
    font-size: 14px;
    font-weight: 500;
    color: #111;
    text-decoration: none;
    letter-spacing: 0.05em;
  }
  .back-link a:hover { text-decoration: underline; }
</style>
