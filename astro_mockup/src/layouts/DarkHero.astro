---
// Layout 4: DARK HERO
// Inverted color scheme — full-bleed dark background with hero image, white
// text. Used for case studies that lean cinematic / data-heavy (e.g. Binance
// Leaderboard, Coinful). Same input shape as HeroComposition but optimized
// for a single dense composition rather than separated mockups.
import BaseLayout from './BaseLayout.astro';

const {
  title,
  subtitle,
  description,
  hero_images = [],
  background_color = '#0E0E0E',
  ...rest
} = Astro.props;
---
<BaseLayout title={title} description={description} {...rest}>
  <section class="hero" style={`background-color: ${background_color}`}>
    <div class="hero-inner">
      {hero_images.map((src) => <img src={src} alt="" loading="eager" />)}
    </div>

    <div class="caption">
      {subtitle && <span class="subtitle">{subtitle}</span>}
      <h1>{title}</h1>
      <p>{description}</p>
    </div>
  </section>

  <section class="content">
    <slot />
  </section>

  <section class="back-link">
    <a href="/">← Back to portfolio</a>
  </section>
</BaseLayout>

<style>
  .hero {
    width: 100%;
    color: #fff;
    padding: 80px 24px 100px;
  }
  .hero-inner {
    max-width: 1280px;
    margin: 0 auto 80px;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 16px;
    align-items: center;
  }
  .hero-inner img {
    width: 100%;
    height: auto;
    object-fit: contain;
    border-radius: 6px;
  }
  .caption {
    max-width: 760px;
    margin: 0 auto;
    padding: 0 24px;
    text-align: center;
  }
  .subtitle {
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.6);
    display: block;
    margin-bottom: 12px;
  }
  .caption h1 {
    font-size: 32px;
    color: #fff;
    margin: 0 0 16px;
  }
  .caption p {
    font-size: 18px;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.85);
    margin: 0;
  }
  .content {
    max-width: 760px;
    margin: 60px auto;
    padding: 0 24px;
  }
  .content :global(p) { margin: 0 0 1.5em; }
  .back-link {
    text-align: center;
    margin: 60px auto 40px;
  }
  .back-link a {
    font-size: 14px;
    font-weight: 500;
    color: #111;
    text-decoration: none;
  }
  .back-link a:hover { text-decoration: underline; }
</style>
