---
// Layout 2: IMAGE GRID
// Title + lead paragraph at top, then a 2-column grid of images with optional
// captions. Each image is its own block — works well for case studies that
// are mostly screenshots (HTC Clock, Mozilla Smart TV, etc.).
// Frontmatter drives:
//   - images: [{ src, caption? }, ...]
import BaseLayout from './BaseLayout.astro';

const { title, subtitle, description, images = [], ...rest } = Astro.props;
---
<BaseLayout title={title} description={description} {...rest}>
  <section class="header">
    {subtitle && <span class="subtitle">{subtitle}</span>}
    <h1>{title}</h1>
    {description && <p class="lead">{description}</p>}
  </section>

  <section class="grid">
    {images.map(({ src, caption }) => (
      <figure>
        <div class="image-frame">
          <img src={src} alt={caption || title} loading="lazy" />
        </div>
        {caption && <figcaption>{caption}</figcaption>}
      </figure>
    ))}
  </section>

  <section class="content">
    <slot />
  </section>

  <section class="back-link">
    <a href="/">← Back to portfolio</a>
  </section>
</BaseLayout>

<style>
  .header {
    max-width: 1200px;
    margin: 80px auto 60px;
    padding: 0 56px;
  }
  .subtitle {
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #999;
    display: block;
    margin-bottom: 12px;
  }
  .header h1 {
    font-size: 26px;
    margin: 0 0 16px;
  }
  .header .lead {
    font-size: 18px;
    line-height: 1.6;
    color: #333;
    max-width: 760px;
    margin: 0;
  }

  .grid {
    max-width: 1200px;
    margin: 0 auto 80px;
    padding: 0 56px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
  }
  @media (max-width: 700px) {
    .header, .grid { padding: 0 24px; }
    .grid { grid-template-columns: 1fr; gap: 20px; }
  }
  figure { margin: 0; }
  .image-frame {
    background: #d9d9d9;
    border-radius: 4px;
    overflow: hidden;
    aspect-ratio: 4 / 5;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .image-frame img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }
  figcaption {
    margin-top: 12px;
    font-size: 13px;
    color: #666;
    line-height: 1.5;
  }

  .content {
    max-width: 760px;
    margin: 60px auto;
    padding: 0 24px;
  }
  .content :global(p) { margin: 0 0 1.5em; }

  .back-link {
    text-align: center;
    margin: 60px auto 40px;
  }
  .back-link a {
    font-size: 14px;
    font-weight: 500;
    color: #111;
    text-decoration: none;
  }
  .back-link a:hover { text-decoration: underline; }
</style>
