---
// Homepage — gallery of all featured projects, grouped by category.
// Re-renders automatically when Ceci adds, removes, or reorders Markdown
// files in src/content/projects/.
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects')).filter((p) => p.data.featured !== false);

// Group projects by category. Order categories explicitly so important ones
// come first (Binance, Blockchain, then earlier work).
const CATEGORY_ORDER = ['Binance', 'Blockchain', 'Acadine', 'Mozilla', 'HTC'];
const CATEGORY_BLURBS: Record<string, string> = {
  Binance: 'Senior Product Designer at Binance — designing the cryptocurrency trading platform.',
  Blockchain: 'Other case studies in Web3 and crypto.',
  Acadine: 'Visual designer at Acadine — feature phone OS, smart home, and digital watch designs.',
  Mozilla: 'Visual designer in the Firefox OS connected device team — TV UI and feature phone concepts.',
  HTC: 'Senior UI designer at HTC — Android & Windows mobile apps, wearables.',
};

const grouped: Record<string, typeof projects> = {};
projects.forEach((p) => {
  const cat = p.data.category || 'Other';
  (grouped[cat] ??= []).push(p);
});
Object.values(grouped).forEach((arr) =>
  arr.sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99))
);

// Pick first hero image as card thumbnail
function thumb(p: typeof projects[number]): string | undefined {
  return p.data.hero_images?.[0] || p.data.images?.[0]?.src;
}
---
<BaseLayout
  title="Ceci's Portfolio 2026"
  description="Ceci Chang — Senior Product Designer / Design Lead. Selected case studies from Binance, TraderWagon, Coinful, iCard.AI, Mozilla, and HTC."
  current="home"
>
  <section class="hero">
    <h1>Hi, I'm Ceci.</h1>
    <p>I am a Senior Product Designer at <a href="https://binance.com" target="_blank" rel="noopener"><strong>Binance</strong></a>.</p>
    <p>I create user-centric, delightful and human experiences.</p>
  </section>

  {CATEGORY_ORDER.filter((c) => grouped[c]?.length).map((cat) => (
    <section class="category">
      <header>
        <h2>{cat}</h2>
        {CATEGORY_BLURBS[cat] && <p>{CATEGORY_BLURBS[cat]}</p>}
      </header>
      <div class="grid">
        {grouped[cat].map((p) => (
          <ProjectCard
            href={`/projects/${p.slug}/`}
            image={thumb(p)}
            title={p.data.title}
            subtitle={p.data.subtitle}
            tint={p.data.background_color}
          />
        ))}
      </div>
    </section>
  ))}
</BaseLayout>

<style>
  .hero {
    max-width: 1100px;
    margin: 60px auto 120px;
    padding: 80px 56px 0;
  }
  .hero h1 {
    font-size: 36px;
    margin: 0 0 16px;
  }
  .hero p {
    font-size: 22px;
    line-height: 1.5;
    color: #333;
    margin: 0 0 8px;
  }
  .hero a { text-decoration: none; }
  .hero a:hover strong { text-decoration: underline; }

  .category {
    max-width: 1200px;
    margin: 0 auto 96px;
    padding: 0 56px;
  }
  .category header { margin-bottom: 32px; }
  .category h2 {
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #666;
    margin: 0 0 8px;
  }
  .category header p {
    max-width: 700px;
    font-size: 16px;
    color: #555;
    margin: 0;
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 24px;
  }

  @media (max-width: 700px) {
    .hero { padding: 40px 24px 0; }
    .hero h1 { font-size: 28px; }
    .hero p { font-size: 18px; }
    .category { padding: 0 24px; margin-bottom: 64px; }
  }
</style>
